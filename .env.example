# API port (Vite dev proxy uses the same value from .env). If 3001 is EADDRINUSE, try 3002.
PORT=3001
NODE_ENV=development

# --- LLM (Gemini — required for /api/assess; get a key from Google AI Studio) ---
GEMINI_API_KEY=your_gemini_key_here
# Same key as above, if your tutorial used this name instead:
# GOOGLE_API_KEY=
# Default model is Gemini 3 Flash (preview). Override if needed:
# GEMINI_MODEL=gemini-3-flash-preview

# Optional: Linkup (cascade enrichment + /api/linkup/search)
LINKUP_API_KEY=your_linkup_key_here
