# API port (Vite dev proxy uses the same value from .env). If 3001 is EADDRINUSE, try 3002.
PORT=3001
NODE_ENV=development

# --- LLM (Claude / Anthropic — required for /api/assess) ---
ANTHROPIC_API_KEY=your_anthropic_key_here
# Default model is Claude Sonnet 4.6. Override if needed:
# ANTHROPIC_MODEL=claude-sonnet-4-6
# Max completion tokens (default 4096; cap 8192). Higher = slower /api/assess.
# ANTHROPIC_MAX_OUTPUT_TOKENS=4096
# Wall-clock timeout for /api/assess in ms (default 120000 = 2 min).
# ASSESS_TIMEOUT_MS=120000
# CLAUDE_API_KEY=   # optional alias for ANTHROPIC_API_KEY

# Optional: Linkup (cascade enrichment + /api/linkup/search)
LINKUP_API_KEY=your_linkup_key_here
